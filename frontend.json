{
  "meta": {
    "specVersion": "1.0",
    "source": "Ui Mock 1.pdf",
    "frontendOnly": true,
    "targetStack": {
      "bundler": "vite",
      "framework": "react",
      "language": "typescript"
    }
  },
  "app": {
    "name": "KneeRecoveryUI",
    "routing": {
      "type": "react-router",
      "routes": [
        { "path": "/", "screenId": "live-dashboard" },
        { "path": "/recovery", "screenId": "recovery-predict" }
      ]
    },
    "dataMode": "mock",
    "state": {
      "user": {
        "username": "",
        "selectedLegUnhealthy": "left",
        "selectedLegHealthy": "right",
        "filename": ""
      },
      "live": {
        "unhealthy": { "kneeAngleDeg": 0, "ypr": { "y": 0, "p": 0, "r": 0 }, "muscleSeries": [] },
        "healthy": { "kneeAngleDeg": 0, "ypr": { "y": 0, "p": 0, "r": 0 }, "muscleSeries": [] }
      },
      "recovery": {
        "kneeAngle": {
          "healthyBaseline": [],
          "unhealthySeries": []
        },
        "kneeStrength": {
          "healthyBaseline": [],
          "unhealthySeries": []
        },
        "predictedFullRecovery": {
          "kneeAngle": { "date": "", "time": "" },
          "kneeStrength": { "date": "", "time": "" }
        }
      }
    }
  },
  "design": {
    "layout": {
      "containerMaxWidth": 1200,
      "padding": 24,
      "gap": 24,
      "headerHeight": 56
    },
    "styleNotes": [
      "Simple wireframe aesthetic: bordered panels, light gray plot areas, minimal color accents for healthy vs unhealthy on recovery screen.",
      "Use placeholder charts (canvas/svg) for knee angle and muscle firing; no backend required."
    ]
  },
  "screens": [
    {
      "id": "live-dashboard",
      "title": "Name of UI",
      "layout": {
        "type": "header + content",
        "header": {
          "left": [{ "type": "iconButton", "id": "closeApp", "label": "X" }],
          "center": [{ "type": "title", "text": "Name of UI" }],
          "right": []
        },
        "content": {
          "type": "grid",
          "columns": 3,
          "columnWidths": ["1fr", "1fr", "260px"],
          "rows": ["auto", "auto"],
          "areas": [
            { "name": "unhealthyKnee", "col": 1, "row": 1 },
            { "name": "healthyKnee", "col": 2, "row": 1 },
            { "name": "actions", "col": 3, "row": 1, "rowSpan": 2 },
            { "name": "unhealthyMuscle", "col": 1, "row": 2 },
            { "name": "healthyMuscle", "col": 2, "row": 2 }
          ]
        }
      },
      "sections": [
        {
          "id": "unhealthyKnee",
          "type": "panel",
          "title": "Unhealthy leg",
          "components": [
            {
              "type": "kneeAngleCanvas",
              "id": "unhealthyKneeCanvas",
              "labels": [
                { "text": "knee angle:", "position": "top-right" },
                { "text": "Y:", "position": "bottom-right" },
                { "text": "P:", "position": "bottom-right" },
                { "text": "R:", "position": "bottom-right" }
              ],
              "binding": "state.live.unhealthy"
            }
          ]
        },
        {
          "id": "healthyKnee",
          "type": "panel",
          "title": "Healthy leg",
          "components": [
            {
              "type": "kneeAngleCanvas",
              "id": "healthyKneeCanvas",
              "labels": [
                { "text": "knee angle:", "position": "top-right" },
                { "text": "Y:", "position": "bottom-right" },
                { "text": "P:", "position": "bottom-right" },
                { "text": "R:", "position": "bottom-right" }
              ],
              "binding": "state.live.healthy"
            }
          ]
        },
        {
          "id": "unhealthyMuscle",
          "type": "panel",
          "title": "Muscle firing graph",
          "components": [
            {
              "type": "lineChartPlaceholder",
              "id": "unhealthyMuscleChart",
              "binding": "state.live.unhealthy.muscleSeries"
            },
            {
              "type": "button",
              "id": "calibrateUnhealthy",
              "text": "Calibrate",
              "variant": "primary"
            }
          ]
        },
        {
          "id": "healthyMuscle",
          "type": "panel",
          "title": "Muscle firing graph",
          "components": [
            {
              "type": "lineChartPlaceholder",
              "id": "healthyMuscleChart",
              "binding": "state.live.healthy.muscleSeries"
            },
            {
              "type": "button",
              "id": "calibrateHealthy",
              "text": "Calibrate",
              "variant": "primary"
            }
          ]
        },
        {
          "id": "actions",
          "type": "sidebar",
          "title": null,
          "components": [
            {
              "type": "button",
              "id": "startCollect",
              "text": "Start Collect",
              "variant": "primary",
              "onClick": [{ "action": "openModal", "target": "collectSetupModal" }]
            },
            {
              "type": "helperText",
              "id": "startCollectHelper",
              "text": "Prompts for user name, unhealthy leg, healthy leg to name file."
            },
            {
              "type": "button",
              "id": "recoveryPredictNav",
              "text": "Recovery Predict",
              "variant": "secondary",
              "onClick": [{ "action": "navigate", "to": "/recovery" }]
            },
            {
              "type": "helperText",
              "id": "recoveryPredictHelper",
              "text": "Goes to next page."
            }
          ]
        }
      ],
      "modals": [
        {
          "id": "collectSetupModal",
          "title": "Start Collection",
          "components": [
            { "type": "textInput", "id": "username", "label": "User name", "binding": "state.user.username" },
            {
              "type": "select",
              "id": "unhealthyLeg",
              "label": "Unhealthy leg",
              "options": ["left", "right"],
              "binding": "state.user.selectedLegUnhealthy"
            },
            {
              "type": "select",
              "id": "healthyLeg",
              "label": "Healthy leg",
              "options": ["left", "right"],
              "binding": "state.user.selectedLegHealthy"
            },
            { "type": "textInput", "id": "filename", "label": "File name", "binding": "state.user.filename" }
          ],
          "footer": [
            { "type": "button", "id": "cancelCollect", "text": "Cancel", "variant": "ghost" },
            { "type": "button", "id": "confirmCollect", "text": "Start", "variant": "primary" }
          ]
        }
      ]
    },
    {
      "id": "recovery-predict",
      "title": "Recovery Predict",
      "layout": {
        "type": "header + content",
        "header": {
          "left": [{ "type": "iconButton", "id": "back", "label": "X", "onClick": [{ "action": "navigate", "to": "/" }] }],
          "center": [{ "type": "title", "text": "Recovery Predict" }],
          "right": []
        },
        "content": {
          "type": "grid",
          "columns": 2,
          "columnWidths": ["1fr", "360px"],
          "rows": ["auto", "auto"],
          "areas": [
            { "name": "angleChart", "col": 1, "row": 1 },
            { "name": "strengthChart", "col": 1, "row": 2 },
            { "name": "predictionPanel", "col": 2, "row": 1, "rowSpan": 2 }
          ]
        }
      },
      "sections": [
        {
          "id": "angleChart",
          "type": "panel",
          "title": null,
          "components": [
            {
              "type": "timeSeriesChartPlaceholder",
              "id": "avgKneeAngleChart",
              "leftAxisLabel": "average knee angle",
              "bottomAxisLabel": "time",
              "series": [
                { "id": "healthyBaseline", "label": "healthy", "binding": "state.recovery.kneeAngle.healthyBaseline" },
                { "id": "unhealthyPredict", "label": "unhealthy", "binding": "state.recovery.kneeAngle.unhealthySeries" }
              ]
            }
          ]
        },
        {
          "id": "strengthChart",
          "type": "panel",
          "title": null,
          "components": [
            {
              "type": "timeSeriesChartPlaceholder",
              "id": "avgKneeStrengthChart",
              "leftAxisLabel": "average knee strength",
              "bottomAxisLabel": "time",
              "series": [
                { "id": "healthyBaseline", "label": "healthy", "binding": "state.recovery.kneeStrength.healthyBaseline" },
                { "id": "unhealthyPredict", "label": "unhealthy", "binding": "state.recovery.kneeStrength.unhealthySeries" }
              ]
            }
          ]
        },
        {
          "id": "predictionPanel",
          "type": "panel",
          "title": "Predicted full recovery",
          "components": [
            {
              "type": "group",
              "id": "kneeAnglePrediction",
              "title": "Knee angle",
              "components": [
                { "type": "textInput", "id": "angleDate", "label": "date", "binding": "state.recovery.predictedFullRecovery.kneeAngle.date" },
                { "type": "textInput", "id": "angleTime", "label": "time", "binding": "state.recovery.predictedFullRecovery.kneeAngle.time" }
              ]
            },
            {
              "type": "group",
              "id": "kneeStrengthPrediction",
              "title": "Knee strength",
              "components": [
                { "type": "textInput", "id": "strengthDate", "label": "date", "binding": "state.recovery.predictedFullRecovery.kneeStrength.date" },
                { "type": "textInput", "id": "strengthTime", "label": "time", "binding": "state.recovery.predictedFullRecovery.kneeStrength.time" }
              ]
            }
          ]
        }
      ]
    }
  ],
  "componentLibrary": {
    "primitives": [
      "AppShell",
      "HeaderBar",
      "Panel",
      "Button",
      "IconButton",
      "TextInput",
      "Select",
      "Modal",
      "Group",
      "HelperText"
    ],
    "custom": [
      "KneeAngleCanvas",
      "LineChartPlaceholder",
      "TimeSeriesChartPlaceholder"
    ]
  }
}
